---
interface Props {
  title: string;
  description: string;
  centered?: boolean;
}

const { title, description, centered } = Astro.props;
---

<section
  class={`flex w-full flex-col mt-16 sm:mt-24 lg:mt-32 px-4 sm:px-6 lg:px-8 mx-auto max-w-7xl ${centered && "justify-center items-center text-center"}`}
>
  <h2 class="text-4xl md:text-6xl w-full font-semibold">{title}</h2>
  <span
    class="max-w-2xl w-full mt-6 text-muted-foreground text-lg sm:text-xl wrap-normal leading-relaxed"
  >
    {description}
  </span>
  <slot />
</section>
